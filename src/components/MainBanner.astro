---
---

<section id="nosotros" class="w-full">

  <!-- Cabecera -->
  <div class="w-full px-6 md:px-12 lg:px-20 max-w-360 mx-auto pt-24 pb-12 flex flex-col md:flex-row md:items-end justify-between gap-8">
    <div class="flex flex-col gap-4">
      <span class="text-xs font-semibold tracking-[0.15em] uppercase text-(--color-text-muted) border border-(--color-border) rounded-full px-3 py-1 w-fit">
        Quiénes somos
      </span>
      <h2 class="text-[clamp(3rem,7vw,8rem)] font-bold leading-[0.95] tracking-[-0.04em] text-(--color-text) uppercase">
        Sintrac<br />Engineering
      </h2>
    </div>
    <div class="flex flex-col gap-5 max-w-sm">
      <p class="text-base text-(--color-text-secondary) leading-relaxed">
        Construimos viviendas en las que las familias confían desde 2003. Calidad, compromiso y rigor en cada proyecto del norte de Madrid.
      </p>
      <a
        href="#contacto"
        class="w-fit px-6 py-3 rounded-full bg-(--color-cta-bg) text-(--color-cta-text) font-medium text-sm no-underline transition-[opacity,transform] duration-150 hover:opacity-75 hover:-translate-y-px"
      >
        Hablar con nosotros →
      </a>
    </div>
  </div>

  <!-- Collage de imágenes -->
  <div class="w-full px-6 md:px-12 lg:px-20 max-w-360 mx-auto pb-16">
    <div class="grid grid-cols-2 md:grid-cols-4 grid-rows-2 gap-3 h-130 md:h-150">

      <!-- Foto grande izquierda (ocupa 2 filas) -->
      <div class="col-span-1 row-span-2 rounded-2xl overflow-hidden bg-(--color-bg-secondary) relative">
        <img src="/obra-1.jpg" alt="Proyecto Sintrac Engineering" class="w-full h-full object-cover" onerror="this.style.display='none'" />
        <div class="absolute inset-0 flex items-center justify-center text-(--color-text-muted) opacity-20 select-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="m21 15-5-5L5 21"></path><circle cx="9" cy="9" r="2"></circle></svg>
        </div>
      </div>

      <!-- Foto ancha central arriba (ocupa 2 columnas) -->
      <div class="col-span-2 row-span-1 rounded-2xl overflow-hidden bg-(--color-bg-secondary) relative">
        <img src="/obra-2.jpg" alt="Proyecto Sintrac Engineering" class="w-full h-full object-cover" onerror="this.style.display='none'" />
        <div class="absolute inset-0 flex items-center justify-center text-(--color-text-muted) opacity-20 select-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="m21 15-5-5L5 21"></path><circle cx="9" cy="9" r="2"></circle></svg>
        </div>
      </div>

      <!-- Foto derecha arriba -->
      <div class="col-span-1 row-span-1 rounded-2xl overflow-hidden bg-(--color-bg-secondary) relative">
        <img src="/obra-3.jpg" alt="Proyecto Sintrac Engineering" class="w-full h-full object-cover" onerror="this.style.display='none'" />
        <div class="absolute inset-0 flex items-center justify-center text-(--color-text-muted) opacity-20 select-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="m21 15-5-5L5 21"></path><circle cx="9" cy="9" r="2"></circle></svg>
        </div>
      </div>

      <!-- Foto central abajo -->
      <div class="col-span-1 row-span-1 rounded-2xl overflow-hidden bg-(--color-bg-secondary) relative">
        <img src="/obra-4.jpg" alt="Proyecto Sintrac Engineering" class="w-full h-full object-cover" onerror="this.style.display='none'" />
        <div class="absolute inset-0 flex items-center justify-center text-(--color-text-muted) opacity-20 select-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="m21 15-5-5L5 21"></path><circle cx="9" cy="9" r="2"></circle></svg>
        </div>
      </div>

      <!-- Foto ancha abajo derecha (ocupa 2 columnas) + cifras encima -->
      <div class="col-span-2 row-span-1 rounded-2xl overflow-hidden bg-(--color-cta-bg) relative flex items-end p-6 gap-8">
        <div>
          <p class="text-3xl font-bold text-white">+19</p>
          <p class="text-xs text-white/50 mt-0.5 uppercase tracking-wide">Años de trayectoria</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white">+13</p>
          <p class="text-xs text-white/50 mt-0.5 uppercase tracking-wide">Proyectos entregados</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white">SANSE</p>
          <p class="text-xs text-white/50 mt-0.5 uppercase tracking-wide">Norte de Madrid</p>
        </div>
      </div>

    </div>
  </div>

</section>
