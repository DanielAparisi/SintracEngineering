<header class="sticky top-0 z-[100]">
  <nav class="flex items-center gap-8 max-w-[1200px] mx-auto px-6 h-[52px]">
    <a
      href="/"
      class="shrink-0 no-underline"
      aria-label="Sintrac Engineering - Inicio"
    >
      <!-- Sustituye por: <img src="/logo.svg" alt="Sintrac Engineering" width="140" height="36" /> -->
      <span
        class="text-base font-semibold tracking-[-0.02em] text-[var(--color-text)]"
      >
        Sintrac Engineering
      </span>
    </a>

    <ul
      class="flex list-none m-0 p-0 gap-1 flex-1 justify-center max-md:hidden"
      role="list"
    >
      <li>
        <a
          href="#proyectos"
          class="block px-3 py-[0.4rem] text-sm text-[var(--color-text-secondary)] no-underline rounded-md transition-[color,background] duration-150 hover:text-[var(--color-text)] hover:bg-black/5"
          >Proyectos</a>
      </li>
      <li>
        <a
          href="#servicios"
          class="block px-3 py-[0.4rem] text-sm text-[var(--color-text-secondary)] no-underline rounded-md transition-[color,background] duration-150 hover:text-[var(--color-text)] hover:bg-black/5"
          >Servicios</a>
      </li>
      <li>
        <a
          href="#obras"
          class="block px-3 py-[0.4rem] text-sm text-[var(--color-text-secondary)] no-underline rounded-md transition-[color,background] duration-150 hover:text-[var(--color-text)] hover:bg-black/5"
          >Obras realizadas</a>
      </li>
      <li>
        <a
          href="#nosotros"
          class="block px-3 py-[0.4rem] text-sm text-[var(--color-text-secondary)] no-underline rounded-md transition-[color,background] duration-150 hover:text-[var(--color-text)] hover:bg-black/5"
          >Nosotros</a>
      </li>
    </ul>

    <a
      href="#contacto"
      class="shrink-0 text-sm font-medium px-4 py-[0.4rem] rounded-full bg-[var(--color-cta-bg)] text-[var(--color-cta-text)] no-underline transition-[opacity,transform] duration-150 hover:opacity-80 hover:-translate-y-px max-md:hidden"
    >
      Contactar
    </a>

    <button
      class="hamburger hidden max-md:flex flex-col justify-center gap-[5px] bg-transparent border-0 cursor-pointer p-1 ml-auto"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span
        class="block w-[22px] h-[2px] bg-[var(--color-text)] rounded-sm transition-[transform,opacity] duration-[250ms]"
      ></span>
      <span
        class="block w-[22px] h-[2px] bg-[var(--color-text)] rounded-sm transition-[transform,opacity] duration-[250ms]"
      ></span>
      <span
        class="block w-[22px] h-[2px] bg-[var(--color-text)] rounded-sm transition-[transform,opacity] duration-[250ms]"
      ></span>
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden flex-col px-6 pt-4 pb-6 border-t border-[var(--color-border)]"
    role="dialog"
    aria-label="Menú de navegación"
  >
    <ul class="list-none m-0 p-0 flex flex-col gap-1" role="list">
      <li>
        <a
          href="#proyectos"
          class="block px-2 py-[0.65rem] text-base text-(--color-text-secondary) no-underline rounded-lg transition-[background,color] duration-150 hover:bg-black/5 hover:text-(--color-text)"
          >Proyectos</a>
      </li>
      <li>
        <a
          href="#servicios"
          class="block px-2 py-[0.65rem] text-base text-(--color-text-secondary) no-underline rounded-lg transition-[background,color] duration-150 hover:bg-black/5 hover:text-(--color-text)"
          >Servicios</a>
      </li>
      <li>
        <a
          href="#obras"
          class="block px-2 py-[0.65rem] text-base text-(--color-text-secondary) no-underline rounded-lg transition-[background,color] duration-150 hover:bg-black/5 hover:text-(--color-text)"
          >Obras realizadas</a>
      </li>
      <li>
        <a
          href="#nosotros"
          class="block px-2 py-[0.65rem] text-base text-(--color-text-secondary) no-underline rounded-lg transition-[background,color] duration-150 hover:bg-black/5 hover:text-(--color-text)"
          >Nosotros</a>
      </li>
      <li>
        <a
          href="#contacto"
          class="block mt-2 px-2 py-[0.65rem] text-base text-center font-medium no-underline rounded-lg bg-(--color-cta-bg) text-(--color-cta-text)"
          >Contactar</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const hamburger = document.querySelector(".hamburger") as HTMLButtonElement;
  const mobileMenu = document.getElementById("mobile-menu") as HTMLElement;

  hamburger.addEventListener("click", () => {
    const isOpen = !mobileMenu.classList.contains("hidden");
    mobileMenu.classList.toggle("hidden");
    mobileMenu.classList.toggle("flex");
    hamburger.classList.toggle("open", !isOpen);
    hamburger.setAttribute("aria-expanded", String(!isOpen));
    hamburger.setAttribute(
      "aria-label",
      !isOpen ? "Cerrar menú" : "Abrir menú",
    );
  });

  document.querySelectorAll("#mobile-menu a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      mobileMenu.classList.remove("flex");
      hamburger.classList.remove("open");
      hamburger.setAttribute("aria-expanded", "false");
      hamburger.setAttribute("aria-label", "Abrir menú");
    });
  });
</script>

<style>
  .hamburger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>
