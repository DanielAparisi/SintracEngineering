---
import SectionContaner from "./SectionContaner.astro";

const schemaData = {
  "@context": "https://schema.org",
  "@type": "GeneralContractor",
  name: "Sintrac Engineering",
  description: "Constructora inmobiliaria con más de 19 años de experiencia en el norte de Madrid.",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Av. de la Zaporra, 147",
    addressLocality: "Alcobendas",
    postalCode: "28100",
    addressRegion: "Madrid",
    addressCountry: "ES",
  },
  telephone: "+34000000000",
  email: "info@sintracengineering.es",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "18:00",
    },
  ],
  geo: {
    "@type": "GeoCoordinates",
    latitude: 40.5341,
    longitude: -3.6395,
  },
};
---

<SectionContaner id="contacto" class="py-24">
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <!-- Encabezado -->
  <div class="flex flex-col items-center gap-3 text-center mb-16">
    <span class="text-xs font-semibold tracking-[0.15em] uppercase text-(--color-text-muted)">Dónde estamos</span>
    <h2 class="text-[clamp(2.5rem,6vw,5rem)] font-bold leading-none tracking-[-0.03em] text-(--color-text)">Ubicación</h2>
  </div>

  <div class="flex flex-col md:flex-row gap-10 items-stretch">

    <!-- Información -->
    <div class="flex flex-col gap-8 md:w-72 shrink-0">

      <div class="flex flex-col gap-1.5">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-(--color-text-muted)">Dirección</p>
        <p class="text-base text-(--color-text-secondary) leading-relaxed">
          Av. de la Zaporra, 147<br />28100 Alcobendas, Madrid
        </p>
      </div>

      <div class="flex flex-col gap-1.5">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-(--color-text-muted)">Horario de oficina</p>
        <p class="text-base text-(--color-text-secondary)">Lunes – Viernes</p>
        <p class="text-sm text-(--color-text-muted)">9:00 – 18:00</p>
      </div>

      <div class="flex flex-col gap-1.5">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-(--color-text-muted)">Teléfono</p>
        <a
          href="tel:+34000000000"
          class="text-base text-(--color-text-secondary) no-underline hover:text-(--color-text) transition-colors duration-150"
        >
          +34 000 000 000
        </a>
      </div>

      <div class="flex flex-col gap-1.5">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-(--color-text-muted)">Email</p>
        <a
          href="mailto:info@sintracengineering.es"
          class="text-base text-(--color-text-secondary) no-underline hover:text-(--color-text) transition-colors duration-150 break-all"
        >
          info@sintracengineering.es
        </a>
      </div>

      <a
        href="https://maps.google.com/?q=Av.+de+la+Zaporra,+147,+28100+Alcobendas,+Madrid"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-auto text-sm font-medium px-5 py-2.5 rounded-full border-2 border-(--color-accent) text-(--color-accent-dark) no-underline hover:bg-(--color-accent) hover:text-white transition-[background,color] duration-150 w-fit"
      >
        Cómo llegar →
      </a>

    </div>

    <!-- Mapa -->
    <div class="flex-1 rounded-2xl overflow-hidden border border-(--color-border) min-h-80">
      <iframe
        title="Ubicación Sintrac Engineering — Av. de la Zaporra, 147, Alcobendas, Madrid"
        width="100%"
        height="100%"
        style="border:0; min-height: 320px;"
        loading="lazy"
        allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
        src="https://maps.google.com/maps?q=Av.+de+la+Zaporra,+147,+28100+Alcobendas,+Madrid&output=embed&hl=es"
      >
      </iframe>
    </div>

  </div>
</SectionContaner>
