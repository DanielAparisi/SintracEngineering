---
import SectionContaner from "./SectionContaner.astro";

const finalizados = [
  {
    img: "https://sintracengineering.es/wp-content/uploads/2025/03/Sintrac--400x284.jpg",
    nombre: "Los Altos de Alcobendas II",
    ubicacion: "Av. de Madrid, 1 · Alcobendas, Madrid",
    año: "2025",
    viviendas: "15",
    descripcion: "Promoción completamente vendida. 15 viviendas con cocina amueblada, salón, 2 dormitorios, 1 baño y 1 aseo. Entrega de llaves completada en plazo y sin incidencias.",
  },
];

const enMarcha = [
  {
    img: "https://sintracengineering.es/wp-content/uploads/2025/03/Sintrac--400x284.jpg",
    nombre: "El Pinar de Prado Norte",
    ubicacion: "Camino de los Malatones, 65 · Algete, Madrid",
    prevision: "2026",
    viviendas: "8",
    descripcion: "Exclusiva promoción de 8 viviendas independientes de obra nueva. Cada vivienda dispone de salón-comedor, 3 dormitorios, dormitorio en suite con vestidor, 3 baños, lavandería, trastero y 3 plazas de garaje. Jardín privado con acceso a zonas comunitarias ajardinadas con piscina salina.",
  },
];
---

<SectionContaner id="proyectos" class="py-32">

  <!-- PROMOCIONES TERMINADAS -->
  <div class="flex flex-col gap-20 mb-36">

    <!-- Título centrado -->
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-xs font-semibold tracking-[0.15em] uppercase text-(--color-text-muted)">Trayectoria</span>
      <h2 class="text-[clamp(2.5rem,6vw,5rem)] font-bold leading-none tracking-[-0.03em] text-(--color-text)">Promociones Terminadas</h2>
    </div>

    <!-- Lista de promociones finalizadas -->
    <div class="flex flex-col">
      {finalizados.map((p, i) => (
        <div class={`flex flex-col md:flex-row items-stretch gap-0 border-t border-(--color-border) py-16 ${i === finalizados.length - 1 ? 'border-b' : ''}`}>

          <!-- Texto izquierda -->
          <div class="flex flex-col justify-between gap-8 flex-1 pr-0 md:pr-16">
            <div class="flex flex-col gap-5">
              <div class="flex items-center gap-3">
                <span class="text-xs font-semibold tracking-[0.12em] uppercase text-(--color-text-muted)">Entregado</span>
                <span class="text-xs font-bold text-(--color-text) bg-(--color-bg-secondary) px-2.5 py-1 rounded-full">{p.año}</span>
              </div>
              <h3 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold leading-tight tracking-[-0.02em] text-(--color-text)">{p.nombre}</h3>
              <p class="text-sm text-(--color-text-muted)">{p.ubicacion}</p>
              <p class="text-base text-(--color-text-secondary) leading-relaxed max-w-md">{p.descripcion}</p>
            </div>
            <div class="flex gap-8">
              <div>
                <p class="text-2xl font-bold text-(--color-text)">{p.viviendas}</p>
                <p class="text-xs text-(--color-text-muted) uppercase tracking-wide mt-0.5">Viviendas</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-(--color-text)">100%</p>
                <p class="text-xs text-(--color-text-muted) uppercase tracking-wide mt-0.5">Vendidas</p>
              </div>
            </div>
          </div>

          <!-- Imagen derecha -->
          <div class="relative w-full md:w-[52%] shrink-0 aspect-16/10 md:aspect-auto rounded-2xl overflow-hidden bg-(--color-bg-secondary) mt-8 md:mt-0">
            <img
              src={p.img}
              alt={p.nombre}
              class="w-full h-full object-cover"
              onerror="this.style.display='none'"
            />
            <div class="absolute inset-0 flex items-center justify-center text-(--color-text-muted) opacity-20 select-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="m21 15-5-5L5 21"></path><circle cx="9" cy="9" r="2"></circle></svg>
            </div>
          </div>

        </div>
      ))}
    </div>
  </div>

  <!-- PROMOCIONES EN MARCHA -->
  <div class="flex flex-col gap-20">

    <!-- Título centrado -->
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-xs font-semibold tracking-[0.15em] uppercase text-(--color-text-muted)">Actualidad</span>
      <h2 class="text-[clamp(2.5rem,6vw,5rem)] font-bold leading-none tracking-[-0.03em] text-(--color-text)">Promociones en Marcha</h2>
    </div>

    <!-- Lista de promociones en marcha -->
    <div class="flex flex-col">
      {enMarcha.map((p, i) => (
        <div class={`flex flex-col md:flex-row items-stretch gap-0 border-t border-(--color-border) py-16 ${i === enMarcha.length - 1 ? 'border-b' : ''}`}>

          <!-- Texto izquierda -->
          <div class="flex flex-col justify-between gap-8 flex-1 pr-0 md:pr-16">
            <div class="flex flex-col gap-5">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                <span class="text-xs font-semibold tracking-[0.12em] uppercase text-green-600">En obras</span>
              </div>
              <h3 class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold leading-tight tracking-[-0.02em] text-(--color-text)">{p.nombre}</h3>
              <p class="text-sm text-(--color-text-muted)">{p.ubicacion}</p>
              <p class="text-base text-(--color-text-secondary) leading-relaxed max-w-md">{p.descripcion}</p>
            </div>
            <div class="flex gap-8">
              <div>
                <p class="text-2xl font-bold text-(--color-text)">{p.viviendas}</p>
                <p class="text-xs text-(--color-text-muted) uppercase tracking-wide mt-0.5">Viviendas</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-(--color-text)">{p.prevision}</p>
                <p class="text-xs text-(--color-text-muted) uppercase tracking-wide mt-0.5">Entrega prevista</p>
              </div>
            </div>
          </div>

          <!-- Imagen derecha -->
          <div class="relative w-full md:w-[52%] shrink-0 aspect-16/10 md:aspect-auto rounded-2xl overflow-hidden bg-(--color-bg-secondary) mt-8 md:mt-0">
            <img
              src={p.img}
              alt={p.nombre}
              class="w-full h-full object-cover"
              onerror="this.style.display='none'"
            />
            <div class="absolute inset-0 flex items-center justify-center text-(--color-text-muted) opacity-20 select-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="m21 15-5-5L5 21"></path><circle cx="9" cy="9" r="2"></circle></svg>
            </div>
          </div>

        </div>
      ))}
    </div>
  </div>

</SectionContaner>
